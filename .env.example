# Restless Pacific local defaults. Copy to .env and replace every committed
# credential and secret before using the production profile.
COMPOSE_PROJECT_NAME=restless-pacific

# Public origins consumed by Caddy and the browser. A bare hostname enables
# automatic HTTPS in production; the local defaults intentionally use HTTP.
WEB_ORIGIN=http://www.localhost
API_ORIGIN=http://api.localhost
ANALYTICS_ORIGIN=http://analytics.localhost
NEXT_PUBLIC_API_BASE_URL=http://api.localhost/api/v1
NEXT_PUBLIC_BASE_PATH=
NEXT_PUBLIC_METABASE_URL=http://analytics.localhost
NEXT_PUBLIC_REPOSITORY_URL=
NEXT_PUBLIC_SITE_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost,http://localhost:3000,http://www.localhost
ACME_EMAIL=ops@example.com

# Optional loopback ports for direct diagnostics. The public entry point is Caddy.
HTTP_PORT=80
HTTPS_PORT=443
POSTGRES_PORT=5432
POSTGRES_PLATFORM=linux/amd64
API_PORT=8080
WEB_PORT=3000
METABASE_PORT=3001

# PostgreSQL/PostGIS. These values are safe only for local development.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=dev-only-postgres-change-me
RING_WRITER_PASSWORD=dev-only-ring-writer-change-me
METABASE_DB_PASSWORD=dev-only-metabase-app-change-me
METABASE_READER_PASSWORD=dev-only-metabase-reader-change-me

# Metabase application and guest embedding. The bootstrap task creates this
# administrator on first run and remains idempotent afterward.
METABASE_ADMIN_EMAIL=atlas-admin@example.test
METABASE_ADMIN_PASSWORD=RestlessPacific-Atlas!2026-Local
METABASE_ADMIN_FIRST_NAME=Restless
METABASE_ADMIN_LAST_NAME=Pacific
METABASE_SITE_NAME="Restless Pacific Data Lab"
METABASE_EMBEDDING_SECRET=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
METABASE_ENCRYPTION_SECRET=dev-only-encryption-secret-change-me-32chars
METABASE_TOKEN_TTL_SECONDS=3600

# Ingestion behavior. Fixture mode makes the first launch deterministic; the
# documented live refresh targets can be run after the stack is healthy.
INGESTION_MODE=fixture
USGS_MIN_MAGNITUDE=2.5
USGS_HISTORY_START=1960-01-01
USGS_POLL_SECONDS=300
USGS_RECONCILE_SECONDS=86400
GVP_REFRESH_SECONDS=604800
PLATE_REFRESH_SECONDS=2592000
NOAA_REFRESH_SECONDS=2592000
SCHEDULER_RUN_SLOW_ON_START=false
USGS_HISTORY_ENABLED=false
NOAA_TSV_URL=
NOAA_DATASET_VERSION=
GVP_EXPECTED_VERSION=5.3.6
GVP_EXPECTED_PROF_VOLCANOES=688
GVP_EXPECTED_PROF_REGIONS=41

# Production image selection. CI publishes immutable sha-* tags to GHCR.
BACKEND_IMAGE=restless-pacific/backend:local
WEB_IMAGE=restless-pacific/web:local
IMAGE_TAG=local

# The ops profile creates encrypted daily backups. Set this to an age public
# recipient (age1...) whose private key is stored off the server.
BACKUP_AGE_RECIPIENT=
BACKUP_INTERVAL_SECONDS=86400
BACKUP_RETENTION_DAYS=14
BACKUP_HOST_PATH=./.data/backups
